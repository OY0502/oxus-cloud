# Optional comma-separated allowlist for grandfathered non-@oxus.agency accounts (Edge Functions).
# Also mirrored in DB table internal_auth_email_allowlist after migration.
# AUTH_EMAIL_ALLOWLIST=hello@oybek.io

# Copy to supabase/functions/.env or pass with --env-file.
# Do not prefix with VITE_. Do not commit real secrets.
# Production values should be set with `supabase secrets set`.

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-5.1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=OXUS Cloud

# Trigger.dev — use tr_prod_ for production edge functions; tr_dev_ for local dev only
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=proj_obirqjqllcyukpslcckr
TRIGGER_API_URL=https://api.trigger.dev
# TRIGGER_PREVIEW_BRANCH=

LANGFUSE_ENABLED=true
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Embeddings — optional. Default: disabled → fallback keyword retrieval.
EMBEDDING_PROVIDER=disabled
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=

# Optional, only if EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

AI_MAX_INPUT_CHARS=120000
AI_CHUNK_SIZE_CHARS=30000
AI_CHUNK_SUMMARY_MODE=extractive
AI_MAX_DIGEST_CHARS=50000

# Firecrawl — server-side only. Do not prefix with VITE_.
# Company website enrichment (enrich-project-from-website). Never called from the browser.
# Production values: supabase secrets set FIRECRAWL_API_KEY="fc-..." FIRECRAWL_API_URL="https://api.firecrawl.dev"
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev
# FIRECRAWL_MAX_PAGES=10
# FIRECRAWL_MAX_CONTENT_CHARS=60000

# Figma server-side only. Do not prefix with VITE_.
# Production values should be set with `supabase secrets set FIGMA_ACCESS_TOKEN="..."`.
FIGMA_ACCESS_TOKEN=
FIGMA_API_BASE_URL=https://api.figma.com
FIGMA_MAX_NODES=300
FIGMA_MAX_TEXT_CHARS=60000

# ClickUp — server-side only. User-triggered API calls use OAuth (below).
CLICKUP_WEBHOOK_ENDPOINT=
CLICKUP_WEBHOOK_SECRET=
CLICKUP_TEAM_ID=
CLICKUP_API_BASE_URL=https://api.clickup.com/api/v2

# Deprecated — not used by user-triggered OAuth flows.
# CLICKUP_API_TOKEN=

# ClickUp OAuth
CLICKUP_OAUTH_CLIENT_ID=
CLICKUP_OAUTH_CLIENT_SECRET=
CLICKUP_OAUTH_REDIRECT_URI=https://YOUR_PROJECT_REF.supabase.co/functions/v1/clickup-oauth-callback
CLICKUP_OAUTH_TOKEN_ENCRYPTION_KEY=
# Production: https://oxus.cloud
# Local dev: http://localhost:5173
CLICKUP_APP_URL=http://localhost:5173
# Optional fallback for server-side app URL resolution in production.
APP_URL=

# Slack OAuth / Events — server-side only. Do not prefix with VITE_.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_OAUTH_REDIRECT_URI=https://YOUR_PROJECT_REF.supabase.co/functions/v1/slack-oauth-callback
SLACK_BOT_TOKEN_ENCRYPTION_KEY=
SLACK_APP_URL=http://localhost:5173
SLACK_API_BASE_URL=https://slack.com/api

# Stripe — server-side only. Do not prefix with VITE_.
# Production: supabase secrets set STRIPE_SECRET_KEY="sk_..." STRIPE_WEBHOOK_SECRET="whsec_..." STRIPE_API_VERSION="2025-02-24.acacia"
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2025-02-24.acacia
