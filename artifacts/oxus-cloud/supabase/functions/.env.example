# Local Edge Function secrets for `supabase functions serve`.
# Copy to supabase/functions/.env or pass with --env-file.
# Production values should be set with `supabase secrets set`, not committed to git.

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=OXUS Cloud

AI_MAX_INPUT_CHARS=50000
