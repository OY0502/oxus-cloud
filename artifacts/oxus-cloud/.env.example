VITE_SUPABASE_URL=https://your-project.supabase.co
# Publishable key from Supabase Project Settings -> API Keys (sb_publishable_... or legacy anon key).
# Never put the service_role/secret key here.
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# OpenRouter — server-side only (Supabase Edge Functions). Do not prefix with VITE_.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=google/gemini-2.5-flash
OPENROUTER_SITE_URL=https://your-app.vercel.app
OPENROUTER_APP_NAME=OXUS Cloud

# AI safety limits
AI_MAX_INPUT_CHARS=50000
