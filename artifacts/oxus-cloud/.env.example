VITE_SUPABASE_URL=https://your-project.supabase.co
# Publishable key from Supabase Project Settings -> API Keys (sb_publishable_... or legacy anon key).
# Never put the service_role/secret key here.
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# OpenRouter model router
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-5.1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=OXUS Cloud

# Trigger.dev — server-side only (Supabase Edge Function secrets + Trigger.dev Cloud env)
# Production edge functions: use tr_prod_... from dashboard → API Keys → Production.
# Local dev only: tr_dev_... works while `pnpm trigger:dev` is running.
# CLI project ref: proj_obirqjqllcyukpslcckr (OXUS Cloud — not oxus-cloud_GIK)
# Deploy tasks: pnpm trigger:deploy
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=proj_obirqjqllcyukpslcckr
TRIGGER_API_URL=https://api.trigger.dev
# Langfuse — server-side only (Supabase Edge Function secrets + Trigger.dev Cloud env)
LANGFUSE_ENABLED=true
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Firecrawl — server-side only (Supabase Edge Function secrets + Trigger.dev Cloud env).
# Do not expose in browser code. Do not prefix with VITE_. Used only for exact-domain
# company website enrichment (enrich-project-from-website). Never called from the browser.
# Production secrets: npx supabase secrets set FIRECRAWL_API_KEY="fc-..." FIRECRAWL_API_URL="https://api.firecrawl.dev"
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev
# Optional enrichment limits (conservative defaults; 4–12 pages).
# FIRECRAWL_MAX_PAGES=10
# FIRECRAWL_MAX_CONTENT_CHARS=60000

# Trigger.dev Cloud environment variables (set in Trigger.dev dashboard → Environment Variables):
# SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, OPENROUTER_API_KEY, OPENROUTER_DEFAULT_MODEL,
# LANGFUSE_ENABLED, LANGFUSE_SECRET_KEY, LANGFUSE_PUBLIC_KEY, LANGFUSE_BASE_URL,
# FIRECRAWL_API_KEY, FIRECRAWL_API_URL

# Embeddings — optional (server-side only). Default: disabled → fallback keyword retrieval.
EMBEDDING_PROVIDER=disabled
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=

# Optional, only if EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# AI safety limits
AI_MAX_INPUT_CHARS=120000
AI_CHUNK_SIZE_CHARS=10000

# Figma server-side only
# Do not expose these in browser code. Do not prefix with VITE_.
# Production secrets should be set with Supabase secrets, e.g.:
#   supabase secrets set FIGMA_ACCESS_TOKEN="..."
FIGMA_ACCESS_TOKEN=
FIGMA_API_BASE_URL=https://api.figma.com
FIGMA_MAX_NODES=300
FIGMA_MAX_TEXT_CHARS=60000

# ClickUp — server-side only (do not prefix with VITE_).
# User-triggered API calls use per-user OAuth (see OAuth block below).
# Production secrets: npx supabase secrets set ...

# Webhook receiver (still required)
CLICKUP_WEBHOOK_ENDPOINT=
CLICKUP_WEBHOOK_SECRET=

# Optional: default workspace when saving OAuth connection
CLICKUP_TEAM_ID=
CLICKUP_API_BASE_URL=https://api.clickup.com/api/v2

# Deprecated — not used by user-triggered OAuth flows. Kept only for legacy reference.
# CLICKUP_API_TOKEN=

# ClickUp OAuth (required for user-triggered ClickUp actions)
# Do not expose these in browser code. Do not prefix with VITE_.
# IMPORTANT: deployed Edge Functions read Supabase secrets, NOT this root .env file.
# After editing here, push to Supabase with:
#   npx supabase secrets set CLICKUP_OAUTH_CLIENT_ID="..." CLICKUP_OAUTH_CLIENT_SECRET="..." ...
# For local `supabase functions serve`, copy these into supabase/functions/.env
CLICKUP_OAUTH_CLIENT_ID=
CLICKUP_OAUTH_CLIENT_SECRET=
CLICKUP_OAUTH_REDIRECT_URI=https://YOUR_PROJECT_REF.supabase.co/functions/v1/clickup-oauth-callback
CLICKUP_OAUTH_TOKEN_ENCRYPTION_KEY=
CLICKUP_APP_URL=http://localhost:5173

# Slack OAuth / Events — server-side only
# Do not expose these in browser code. Do not prefix with VITE_.
# Deployed Edge Functions read Supabase secrets, NOT this file. After editing, push ALL Slack OAuth
# values together (client id + client secret must be from the same app):
#   npx supabase secrets set SLACK_CLIENT_ID="..." SLACK_CLIENT_SECRET="..." SLACK_OAUTH_REDIRECT_URI="..."
# Client Secret ≠ Signing Secret (both are 32-char hex — easy to mix up).
# Bot scopes: users:read + users:read.email (recommended for internal/client author matching).
# Reinstall the Slack app after adding users:read.email.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_OAUTH_REDIRECT_URI=https://YOUR_PROJECT_REF.supabase.co/functions/v1/slack-oauth-callback
SLACK_BOT_TOKEN_ENCRYPTION_KEY=
SLACK_APP_URL=http://localhost:5173
SLACK_API_BASE_URL=https://slack.com/api
